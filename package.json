{
  "name": "quartz",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build": "ng build quartz",
    "build:demo": "ng build demo",
    "pages:build": "ng build demo --configuration production",
    "pages:deploy": "pnpm pages:build && wrangler pages deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p packages/quartz/tsconfig.lib.json && tsc --noEmit -p app/tsconfig.app.json",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint \"{packages/quartz,app}/**/*.{ts,html}\"",
    "format": "prettier --write \"**/*.{ts,html,scss,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,html,scss,json,md}\"",
    "quartz": "node cli/bin/quartz.js"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/vitest-angular": "^2.4.0",
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular-eslint/builder": "21.3.1",
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/schematics": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/build": "^21.0.4",
    "@angular/cli": "^21.0.4",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.2.6",
    "@angular/platform-server": "^21.0.0",
    "@playwright/test": "^1.59.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^20.17.19",
    "@typescript-eslint/eslint-plugin": "7.11.0",
    "@typescript-eslint/parser": "7.11.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.1.0",
    "ng-packagr": "^21.2.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
