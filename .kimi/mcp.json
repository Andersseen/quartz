{
  "mcpServers": {
    "volt-ui": {
      "type": "url",
      "url": "https://volt-ui.pages.dev/api/mcp"
    },
    "angular": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@angular/cli", "mcp"]
    },
    "vitest": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@djankies/vitest-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"],
      "description": "Browser automation via Playwright — for running, debugging and inspecting E2E tests"
    }
  }
}
